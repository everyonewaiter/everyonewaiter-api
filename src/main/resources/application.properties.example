spring.application.name=everyonewaiter-api
server.port=8080
spring.profiles.active=<local | dev | prod>
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

# ACTUATOR
server.tomcat.mbeanregistry.enabled=true
management.endpoints.web.exposure.include=*
management.endpoint.health.show-details=always
management.info.java.enabled=true
management.info.os.enabled=true

# CLIENT
allow.client.urls=http://localhost:3000,http://localhost:8080

# DB
spring.datasource.url=jdbc:mysql://localhost:3306/everyonewaiter?rewriteBatchedStatements=true
spring.datasource.username=root
spring.datasource.password=1234
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# SQL
spring.sql.init.mode=never
spring.sql.init.schema-locations=classpath:db/schema.sql
logging.level.org.springframework.jdbc=info

# REDIS
spring.data.redis.host=localhost
spring.data.redis.port=6379
spring.data.redis.password=1234

# JWT
jwt.secret-key=<SECRET_KEY>

# MAIL
spring.mail.host=<HOST>
spring.mail.username=<USERNAME>
spring.mail.password=<PASSWORD>
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.mime.charset=UTF-8

# NAVER SENS
naver.sens.access-key=<ACCESS_KEY>
naver.sens.secret-key=<SECRET_KEY>
naver.sens.service-id=<SERVICE_ID>
naver.sens.channel-id=<CHANNEL_ID>

# EVENT NOTIFICATION
event.discord.webhook=<DISCORD_WEBHOOK_URI>

# ORACLE OBJECT STORAGE
oracle.object.storage.namespace=<NAMESPACE>
oracle.object.storage.bucket-name=<BUCKET_NAME>

# LOG
logging.config=classpath:logback/logback-spring.xml
logging.level.feign=debug
logging.discord.webhook=<DISCORD_WEBHOOK_URI>

# SWAGGER
springdoc.swagger-ui.enabled=true
springdoc.default-consumes-media-type=application/json;charset=UTF-8
springdoc.default-produces-media-type=application/json;charset=UTF-8
springdoc.api-docs.path=/api/documents.json
springdoc.swagger-ui.path=/api/documents
springdoc.swagger-ui.disable-swagger-default-url=true
springdoc.swagger-ui.display-request-duration=true
springdoc.swagger-ui.persist-authorization=true
springdoc.swagger-ui.tags-sorter=alpha
springdoc.swagger-ui.operations-sorter=method
